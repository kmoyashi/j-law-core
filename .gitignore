# =============================================================================
# Rust / Cargo
# =============================================================================

# ビルド成果物（workspace はルートの target/ に集約される）
/target/

# バックアップファイル
*.rs.bk

# =============================================================================
# Python / PyO3 (crates/j-law-python)
# =============================================================================

__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
dist/
build/
*.egg-info/
.venv/
venv/
.pytest_cache/

# maturin / pip ビルド成果物
wheels/

# =============================================================================
# WebAssembly / wasm-pack (crates/j-law-wasm)
# =============================================================================

# wasm-pack が生成するパッケージ（再生成可能）
crates/j-law-wasm/pkg/

# =============================================================================
# Ruby / rake-compiler (crates/j-law-ruby)
# =============================================================================

# rake-compiler のビルド作業ディレクトリ
crates/j-law-ruby/tmp/

# C ABI 用にビルドした共有ライブラリ
crates/j-law-ruby/lib/j_law_ruby/native/

# source gem 用に同期した Rust ワークスペース
crates/j-law-ruby/vendor/rust/

# extconf が生成する Makefile
crates/j-law-ruby/ext/j_law_ruby/Makefile

# source gem ビルド成果物
crates/j-law-ruby/*.gem

# Bundler
crates/j-law-ruby/.bundle/
crates/j-law-ruby/vendor/bundle/

# Ruby dependency lockfile is generated locally for validation in this repo
crates/j-law-ruby/Gemfile.lock

# =============================================================================
# Claude Code
# =============================================================================

# ローカル設定（個人の API キー・設定が含まれる場合がある）
.claude/settings.local.json

# =============================================================================
# Codex
# =============================================================================

# Codex のローカル設定・実行状態
.codex/

# =============================================================================
# macOS
# =============================================================================

.DS_Store
.AppleDouble
.LSOverride

# =============================================================================
# エディタ
# =============================================================================

.idea/
.vscode/settings.json
.vscode/launch.json
*.swp
*.swo
*~

# =============================================================================
# 環境変数・秘密情報
# =============================================================================

.env
.env.local
.env.*.local
